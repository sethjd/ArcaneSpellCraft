{
  "name": "arcane-spell-craft",
  "version": "0.1.0",
  "description": "Arcane Spell Craft desktop wrapper for Steam/PC testing.",
  "main": "main.js",
  "author": "sethjd",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable",
    "dist:win-installer": "electron-builder --win nsis",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.sethjd.arcanespellcraft",
    "productName": "Arcane Spell Craft",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "www/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}