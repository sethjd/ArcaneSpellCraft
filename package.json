{
  "name": "arcane-spell-craft",
  "version": "0.6.3",
  "description": "Arcane Spell Craft desktop build for PC and Steam testing.",
  "main": "main.js",
  "author": "sethjd",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable nsis --publish never",
    "dist:win-portable": "electron-builder --win portable --publish never",
    "dist:win-installer": "electron-builder --win nsis --publish never",
    "dist": "electron-builder --publish never"
  },
  "build": {
    "appId": "com.sethjd.arcanespellcraft",
    "productName": "Arcane Spell Craft",
    "copyright": "Copyright \u00a9 2026 sethjd",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "www/**/*",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "ArcaneSpellCraft-${version}-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "ArcaneSpellCraft-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arcane Spell Craft",
      "artifactName": "ArcaneSpellCraft-${version}-setup.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}